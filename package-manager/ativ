#!/usr/bin/env bash
#
# ativ - the AtivOS package manager
#
# A single frontend across three tiers, checked in order: pacman (official
# repos) -> flatpak (flathub) -> AUR (build from source). One tool, one
# syntax, no "which helper/store is this in again" confusion. Designed to
# run as a normal user (it calls sudo internally only for the actual pacman
# transactions) so AUR builds never run as root.
#
# Commands:
#   ativ install   <pkg...>     install: tries pacman, then flatpak, then AUR
#   ativ remove     <pkg...>     remove a package (+ unneeded deps), guards core pkgs
#   ativ search     <term>       search official repos + flatpak + AUR, merged & tagged
#   ativ info       <pkg>        show details from whichever tier has the package
#   ativ update                  sync + upgrade official packages
#   ativ upgrade                 update + upgrade flatpak apps + AUR/foreign packages too
#   ativ os-upgrade              re-clone AtivOS from GitHub and re-run install-all.sh
#   ativ list       [flag]       list installed packages (--explicit/--foreign/--flatpak/--all)
#   ativ autoremove              remove orphaned dependencies
#   ativ clean       [--all]     clean package cache (+ ativ's AUR build cache)
#   ativ log         [n]         show last n ativ actions (default 20)
#   ativ doctor                  sanity-check the system (keys, .pacnew, orphans...)
#   ativ --help
#
set -uo pipefail

VERSION="ativ 1.1.0 (AtivOS)"
CONFIG_FILE="/etc/ativ/ativ.conf"
LOG_FILE="/var/log/ativ.log"
AUR_RPC="https://aur.archlinux.org/rpc/v5"
AUR_GIT="https://aur.archlinux.org"

# ---- config defaults (overridable via /etc/ativ/ativ.conf) ----------------
COLOR=true
NOCONFIRM=false
PROTECTED_PACKAGES="base base-devel linux linux-lts linux-firmware systemd glibc sudo pacman filesystem"
BUILD_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ativ/build"
FLATPAK_REMOTE="flathub"
ATIVOS_REPO_URL="https://github.com/SkywareSW/AtivOS.git"
ATIVOS_REPO_DIR="${HOME:-/root}/AtivOS"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# ---- colors -----------------------------------------------------------
if [[ "$COLOR" == true && -t 1 ]]; then
    C_RESET='\033[0m'; C_INFO='\033[1;34m'; C_OK='\033[1;32m'
    C_WARN='\033[1;33m'; C_ERR='\033[1;31m'; C_DIM='\033[2m'
else
    C_RESET=''; C_INFO=''; C_OK=''; C_WARN=''; C_ERR=''; C_DIM=''
fi

info()  { echo -e "${C_INFO}::${C_RESET} $*"; }
ok()    { echo -e "${C_OK}==>${C_RESET} $*"; }
warn()  { echo -e "${C_WARN}!!${C_RESET} $*" >&2; }
err()   { echo -e "${C_ERR}xx${C_RESET} $*" >&2; }

# ---- spinner animation for silent steps (network calls, git clones) ------
# pacman/makepkg/flatpak already print their own live progress, so those are
# left alone; this is for the previously-silent steps in between where ativ
# would otherwise just sit there with no feedback.
SPIN_FRAMES=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')

run_with_spinner() {
    local msg="$1"; shift
    local logfile status i=0
    logfile=$(mktemp)

    if [[ "$COLOR" != true || ! -t 1 ]]; then
        info "$msg"
        "$@" >"$logfile" 2>&1
        status=$?
    else
        ("$@" >"$logfile" 2>&1) &
        local pid=$!
        while kill -0 "$pid" 2>/dev/null; do
            printf "\r${C_INFO}%s${C_RESET} %s" "${SPIN_FRAMES[i % ${#SPIN_FRAMES[@]}]}" "$msg"
            i=$((i + 1))
            sleep 0.08
        done
        wait "$pid"
        status=$?
        printf "\r\033[K"
    fi

    if [[ $status -eq 0 ]]; then
        ok "$msg"
    else
        err "$msg (failed)"
        cat "$logfile" >&2
    fi
    rm -f "$logfile"
    return $status
}

log_action() {
    local msg="$1"
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    if [[ -w "$(dirname "$LOG_FILE")" || -w "$LOG_FILE" ]]; then
        echo "[$ts] $msg" | sudo tee -a "$LOG_FILE" >/dev/null 2>&1 || true
    fi
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || { err "Required command '$1' not found."; exit 1; }
}

confirm() {
    local prompt="$1"
    [[ "$NOCONFIRM" == true ]] && return 0
    read -rp "$prompt [y/N] " reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

is_protected() {
    local pkg="$1"
    for p in $PROTECTED_PACKAGES; do
        [[ "$pkg" == "$p" ]] && return 0
    done
    return 1
}

# ---- AUR helpers (curl + git + makepkg, no external AUR helper needed) ----
aur_info() {
    local pkg="$1"
    curl -fsS --get "$AUR_RPC/info" --data-urlencode "arg[]=$pkg" 2>/dev/null
}

aur_search() {
    local term="$1"
    curl -fsS "$AUR_RPC/search/$term" 2>/dev/null
}

aur_json_field() {
    # crude JSON field extraction to avoid a hard dependency on jq
    local json="$1" field="$2"
    echo "$json" | grep -o "\"$field\":\"[^\"]*\"" | head -1 | sed -E "s/\"$field\":\"([^\"]*)\"/\1/"
}

aur_exists() {
    local pkg="$1"
    local result
    result=$(aur_info "$pkg")
    [[ "$result" == *"\"resultcount\":1"* || "$result" == *"\"resultcount\":2"* ]] || \
    echo "$result" | grep -q "\"Name\":\"$pkg\""
}

aur_build_install() {
    local pkg="$1"
    need_cmd git; need_cmd makepkg

    if [[ "$EUID" -eq 0 ]]; then
        err "AUR packages can't be built as root. Re-run 'ativ install $pkg' as your normal user."
        return 1
    fi

    mkdir -p "$BUILD_DIR"
    local pkg_dir="$BUILD_DIR/$pkg"

    if [[ -d "$pkg_dir/.git" ]]; then
        run_with_spinner "Fetching latest changes for $pkg" git -C "$pkg_dir" pull --quiet
    else
        rm -rf "$pkg_dir"
        run_with_spinner "Fetching AUR package: $pkg" git clone --quiet "$AUR_GIT/$pkg.git" "$pkg_dir" || {
            err "Could not clone '$pkg' from the AUR. Does the package name exist?"
            return 1
        }
    fi

    info "Building $pkg (you may be prompted for your sudo password)"
    (cd "$pkg_dir" && makepkg -si --noconfirm="$NOCONFIRM") || {
        err "Build failed for $pkg"
        return 1
    }
    log_action "installed (AUR): $pkg"
    ok "$pkg installed from AUR"
}

# ---- Flatpak helpers ------------------------------------------------------
flatpak_available() {
    command -v flatpak >/dev/null 2>&1
}

flatpak_ensure_remote() {
    flatpak_available || return 1
    if ! flatpak remote-list 2>/dev/null | grep -q "^$FLATPAK_REMOTE"; then
        warn "Flathub remote isn't set up yet."
        confirm "Add the Flathub remote now?" || return 1
        run_with_spinner "Adding Flathub remote" sudo flatpak remote-add --if-not-exists "$FLATPAK_REMOTE" https://flathub.org/repo/flathub.flatpakrepo
    fi
    return 0
}

# Resolves a loose name (e.g. "spotify") to a real flatpak application ID
# (e.g. "com.spotify.Client"), preferring an exact ID match if given.
flatpak_resolve_id() {
    local term="$1"
    flatpak_available || return 1
    local match
    match=$(flatpak remote-ls "$FLATPAK_REMOTE" --app --columns=application 2>/dev/null | grep -ix "$term")
    if [[ -n "$match" ]]; then
        echo "$match"; return 0
    fi
    match=$(flatpak remote-ls "$FLATPAK_REMOTE" --app --columns=application,name 2>/dev/null | \
            awk -v t="$term" 'BEGIN{IGNORECASE=1} tolower($0) ~ tolower(t) {print $1; exit}')
    [[ -n "$match" ]] && { echo "$match"; return 0; }
    return 1
}

flatpak_install() {
    local pkg="$1"
    flatpak_ensure_remote || { err "Flatpak/Flathub not available."; return 1; }
    local app_id
    app_id=$(flatpak_resolve_id "$pkg") || { return 1; }
    info "Installing (flatpak): $app_id"
    flatpak install -y "$FLATPAK_REMOTE" "$app_id" && log_action "installed (flatpak): $app_id"
}

flatpak_is_installed() {
    local pkg="$1"
    flatpak_available || return 1
    flatpak list --app --columns=application 2>/dev/null | grep -ix "$pkg" >/dev/null 2>&1
}

flatpak_remove() {
    local pkg="$1"
    flatpak uninstall -y "$pkg" && log_action "removed (flatpak): $pkg"
}

# ---- core commands ------------------------------------------------------
cmd_install() {
    [[ $# -eq 0 ]] && { err "Usage: ativ install <package...>"; exit 1; }

    local official=() flatpak=() aur=()
    local i=0 total=$#
    for pkg in "$@"; do
        i=$((i + 1))
        if [[ -t 1 && "$COLOR" == true ]]; then
            printf "\r${C_INFO}%s${C_RESET} Resolving %s ${C_DIM}(%d/%d)${C_RESET}" \
                "${SPIN_FRAMES[i % ${#SPIN_FRAMES[@]}]}" "$pkg" "$i" "$total"
        fi
        if pacman -Si "$pkg" >/dev/null 2>&1; then
            official+=("$pkg")
        elif flatpak_available && flatpak_resolve_id "$pkg" >/dev/null 2>&1; then
            flatpak+=("$pkg")
        else
            aur+=("$pkg")
        fi
    done
    [[ -t 1 && "$COLOR" == true ]] && printf "\r\033[K"

    if [[ ${#official[@]} -gt 0 ]]; then
        info "Installing from official repos: ${official[*]}"
        sudo pacman -S --needed "${official[@]}" && \
            for p in "${official[@]}"; do log_action "installed (repo): $p"; done
    fi

    for pkg in "${flatpak[@]}"; do
        flatpak_install "$pkg"
    done

    for pkg in "${aur[@]}"; do
        if aur_exists "$pkg" >/dev/null 2>&1 || [[ -n "$(aur_info "$pkg")" ]]; then
            aur_build_install "$pkg"
        else
            err "Package '$pkg' not found in official repos, Flathub, or the AUR."
        fi
    done
}

cmd_remove() {
    [[ $# -eq 0 ]] && { err "Usage: ativ remove <package...>"; exit 1; }

    for pkg in "$@"; do
        if pacman -Qi "$pkg" >/dev/null 2>&1; then
            if is_protected "$pkg"; then
                warn "'$pkg' is a core system package."
                confirm "Really remove $pkg? This can break your system." || { info "Skipped $pkg"; continue; }
            fi
            sudo pacman -Rns --noconfirm="$NOCONFIRM" "$pkg" && log_action "removed: $pkg"
        elif flatpak_is_installed "$pkg"; then
            flatpak_remove "$pkg"
        else
            err "'$pkg' doesn't appear to be installed (checked pacman + flatpak)."
        fi
    done
}

cmd_search() {
    [[ $# -eq 0 ]] && { err "Usage: ativ search <term>"; exit 1; }
    local term="$1"

    info "Official repos:"
    pacman -Ss "$term" | sed -E "s/^([a-z0-9._+-]+\/[a-zA-Z0-9._+-]+)/${C_OK}[repo]${C_RESET} \1/" || true

    echo ""
    info "Flatpak (Flathub):"
    if flatpak_available; then
        flatpak remote-ls "$FLATPAK_REMOTE" --app --columns=application,name,version 2>/dev/null | \
            awk -v IGNORECASE=1 -v t="$term" 'tolower($0) ~ tolower(t)' | head -15 | \
            awk -v c="$C_INFO" -v r="$C_RESET" '{printf "  %s[flatpak]%s %s\n", c, r, $0}'
    else
        echo "  (flatpak not installed)"
    fi

    echo ""
    info "AUR:"
    local result
    result=$(aur_search "$term")
    if [[ -n "$result" ]]; then
        echo "$result" | grep -o '"Name":"[^"]*","Version":"[^"]*","Description":[^,]*' | \
        sed -E 's/"Name":"([^"]*)","Version":"([^"]*)","Description":"?([^"]*)"?/'"${C_WARN}"'[aur] '"${C_RESET}"'\1 \2 - \3/' | head -20
    else
        echo "  (no results or AUR unreachable)"
    fi
}

cmd_info() {
    [[ $# -eq 0 ]] && { err "Usage: ativ info <package>"; exit 1; }
    local pkg="$1"
    local fp_id
    if pacman -Si "$pkg" >/dev/null 2>&1; then
        pacman -Si "$pkg"
    elif pacman -Qi "$pkg" >/dev/null 2>&1; then
        pacman -Qi "$pkg"
    elif flatpak_available && fp_id=$(flatpak_resolve_id "$pkg" 2>/dev/null) && [[ -n "$fp_id" ]]; then
        flatpak remote-info "$FLATPAK_REMOTE" "$fp_id" 2>/dev/null || \
            flatpak info "$fp_id" 2>/dev/null
    else
        local result
        result=$(aur_info "$pkg")
        if [[ -n "$result" && "$result" != *'"resultcount":0'* ]]; then
            echo "Name        : $(aur_json_field "$result" Name)"
            echo "Version     : $(aur_json_field "$result" Version)"
            echo "Description : $(aur_json_field "$result" Description)"
            echo "Maintainer  : $(aur_json_field "$result" Maintainer)"
            echo "Source      : AUR ($AUR_GIT/$pkg.git)"
        else
            err "Package '$pkg' not found."
            exit 1
        fi
    fi
}

cmd_update() {
    info "Syncing and upgrading official packages"
    sudo pacman -Syu --noconfirm="$NOCONFIRM" && log_action "system update (repo)"
}

cmd_upgrade() {
    cmd_update

    if flatpak_available; then
        info "Updating flatpak apps"
        flatpak update -y && log_action "flatpak update"
    fi

    info "Checking AUR/foreign packages for updates"
    local foreign
    foreign=$(pacman -Qm | awk '{print $1}')
    [[ -z "$foreign" ]] && { ok "No foreign/AUR packages installed."; return; }

    local to_upgrade=()
    local fi=0 ftotal
    ftotal=$(echo "$foreign" | wc -l)
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        fi=$((fi + 1))
        if [[ -t 1 && "$COLOR" == true ]]; then
            printf "\r${C_INFO}%s${C_RESET} Checking %s ${C_DIM}(%d/%d)${C_RESET}\033[K" \
                "${SPIN_FRAMES[fi % ${#SPIN_FRAMES[@]}]}" "$pkg" "$fi" "$ftotal"
        fi
        local installed_ver aur_ver result
        installed_ver=$(pacman -Q "$pkg" 2>/dev/null | awk '{print $2}')
        result=$(aur_info "$pkg")
        aur_ver=$(aur_json_field "$result" Version)
        if [[ -n "$aur_ver" && "$aur_ver" != "$installed_ver" ]]; then
            to_upgrade+=("$pkg")
            printf "\r\033[K  %s: %s -> %s\n" "$pkg" "$installed_ver" "$aur_ver"
        fi
    done <<< "$foreign"
    [[ -t 1 && "$COLOR" == true ]] && printf "\r\033[K"

    if [[ ${#to_upgrade[@]} -eq 0 ]]; then
        ok "All AUR packages are up to date."
        return
    fi

    confirm "Rebuild and upgrade ${#to_upgrade[@]} AUR package(s)?" || { info "Skipped."; return; }
    for pkg in "${to_upgrade[@]}"; do
        aur_build_install "$pkg"
    done
}

cmd_os_upgrade() {
    need_cmd git

    info "Removing old AtivOS folder: $ATIVOS_REPO_DIR"
    rm -rf "$ATIVOS_REPO_DIR"

    run_with_spinner "Fetching latest AtivOS from GitHub" git clone --quiet "$ATIVOS_REPO_URL" "$ATIVOS_REPO_DIR" || {
        err "Could not clone $ATIVOS_REPO_URL"
        return 1
    }

    cd "$ATIVOS_REPO_DIR" || { err "Could not enter $ATIVOS_REPO_DIR"; return 1; }

    info "Making install-all.sh executable"
    chmod +x install-all.sh

    info "Running install-all.sh (you may be prompted for your sudo password)"
    sudo ./install-all.sh

    log_action "os-upgrade: reinstalled AtivOS from $ATIVOS_REPO_URL"
    ok "AtivOS reinstalled from latest GitHub source."
}

cmd_list() {
    case "${1:-}" in
        --explicit|-e) pacman -Qe ;;
        --foreign|-m)  pacman -Qm ;;
        --flatpak|-f)
            if flatpak_available; then
                flatpak list --app --columns=application,version,name
            else
                warn "flatpak not installed."
            fi
            ;;
        --all|-a|"")   pacman -Q ;;
        *) err "Unknown flag '$1'. Use --explicit, --foreign, --flatpak, or --all."; exit 1 ;;
    esac
}

cmd_autoremove() {
    local orphans
    orphans=$(pacman -Qdtq 2>/dev/null)
    if [[ -z "$orphans" ]]; then
        ok "No orphaned packages to remove."
        return
    fi
    info "Orphaned packages:"
    echo "$orphans"
    confirm "Remove these ${#orphans} package(s)?" || { info "Skipped."; return; }
    # shellcheck disable=SC2086
    sudo pacman -Rns --noconfirm="$NOCONFIRM" $orphans && log_action "autoremove: $(echo "$orphans" | tr '\n' ' ')"
}

cmd_clean() {
    if [[ "${1:-}" == "--all" ]]; then
        sudo pacman -Scc --noconfirm="$NOCONFIRM"
        rm -rf "$BUILD_DIR"
        ok "Cleared full package cache and ativ build cache."
    else
        sudo pacman -Sc --noconfirm="$NOCONFIRM"
        ok "Cleared unused package cache (kept installed versions)."
    fi
    log_action "clean ${1:-}"
}

cmd_log() {
    local n="${1:-20}"
    if [[ -f "$LOG_FILE" ]]; then
        tail -n "$n" "$LOG_FILE"
    else
        warn "No ativ log yet at $LOG_FILE."
    fi
}

cmd_doctor() {
    info "Checking pacman keyring..."
    if ! pacman-key --list-keys >/dev/null 2>&1; then
        warn "pacman keyring looks uninitialized. Run: sudo pacman-key --init && sudo pacman-key --populate archlinux"
    else
        ok "Keyring OK."
    fi

    info "Checking for .pacnew files..."
    local pacnew
    pacnew=$(sudo find /etc -name '*.pacnew' 2>/dev/null)
    if [[ -n "$pacnew" ]]; then
        warn "Found .pacnew files that may need merging:"
        echo "$pacnew"
    else
        ok "No pending .pacnew files."
    fi

    info "Checking for orphaned packages..."
    local orphans
    orphans=$(pacman -Qdtq 2>/dev/null)
    if [[ -n "$orphans" ]]; then
        warn "Orphaned packages present (run 'ativ autoremove'):"
        echo "$orphans"
    else
        ok "No orphans."
    fi

    info "Checking database integrity..."
    if sudo pacman -Dk >/dev/null 2>&1; then
        ok "Package database integrity OK."
    else
        err "Database integrity check reported problems (see: sudo pacman -Dk)."
    fi

    info "Checking flatpak/flathub..."
    if flatpak_available; then
        if flatpak remote-list 2>/dev/null | grep -q "^$FLATPAK_REMOTE"; then
            ok "Flatpak installed, Flathub remote configured."
        else
            warn "Flatpak is installed but Flathub remote is missing. Run: sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo"
        fi
    else
        warn "Flatpak not installed — the flatpak tier of 'ativ install' will be skipped. Install with: ativ install flatpak"
    fi
}

usage() {
    cat <<EOF
$VERSION

Usage: ativ <command> [args]

Install order: pacman (official repos) -> flatpak (Flathub) -> AUR (built from source)

Commands:
  install <pkg...>     Install package(s), trying pacman, then flatpak, then AUR
  remove  <pkg...>     Remove package(s) (pacman or flatpak), guards core pkgs
  search  <term>        Search official repos + flatpak + AUR
  info    <pkg>          Show package details from whichever tier has it
  update                 Sync + upgrade official packages
  upgrade                Update official + flatpak apps + AUR/foreign packages
  os-upgrade              Re-clone AtivOS from GitHub and re-run install-all.sh
  list    [--explicit|--foreign|--flatpak|--all]   List installed packages
  autoremove             Remove orphaned dependencies
  clean   [--all]         Clean package cache
  log     [n]             Show last n log entries (default 20)
  doctor                  Run system sanity checks

Flags:
  -y, --noconfirm         Assume yes to all prompts
  -h, --help              Show this help
  -v, --version           Show version
EOF
}

# ---- arg parsing ---------------------------------------------------------
[[ $# -eq 0 ]] && { usage; exit 1; }

ARGS=()
for a in "$@"; do
    case "$a" in
        -y|--noconfirm) NOCONFIRM=true ;;
        -h|--help) usage; exit 0 ;;
        -v|--version) echo "$VERSION"; exit 0 ;;
        *) ARGS+=("$a") ;;
    esac
done
set -- "${ARGS[@]}"

need_cmd pacman
need_cmd curl

CMD="${1:-}"; shift || true

case "$CMD" in
    install)     cmd_install "$@" ;;
    remove|rm)   cmd_remove "$@" ;;
    search)      cmd_search "$@" ;;
    info)        cmd_info "$@" ;;
    update)      cmd_update ;;
    upgrade)     cmd_upgrade ;;
    os-upgrade)  cmd_os_upgrade ;;
    list)        cmd_list "$@" ;;
    autoremove)  cmd_autoremove ;;
    clean)       cmd_clean "$@" ;;
    log)         cmd_log "$@" ;;
    doctor)      cmd_doctor ;;
    *) err "Unknown command: $CMD"; usage; exit 1 ;;
esac
